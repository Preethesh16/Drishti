# Copy to .env and fill in. .env is gitignored — NEVER commit real keys.

# Salt for hashing PII (name/mobile). Use a long random string in prod.
SETU_SALT=change-me-to-a-long-random-string

# Claude (Tier-2 cross-lingual matcher + explanations). Optional — core runs offline without it.
ANTHROPIC_API_KEY=

# Sarvam AI (voice ASR/TTS/translate for Indian languages). Optional — falls back to typed input.
SARVAM_API_KEY=
